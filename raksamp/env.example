# Скопируйте в `raksamp/.env` и при необходимости поправьте значения.
# Подключение в текущей оболочке:  set -a && source raksamp/.env && set +a

# Wine 32-bit для RakSAMP / RakSAMP Lite (см. raksamp/SETUP.md)
export WINEARCH=win32
export WINEPREFIX="${HOME}/.wine-raksamp32"

# Дисплей: реальный X11 или виртуальный (:1 при Xvfb)
export DISPLAY="${DISPLAY:-:1}"

# Пароль для диалогов register/password в Lite (опционально)
# export LITE_REGISTER_PASSWORD=''

# Путь к архиву RakSAMP Lite, если не стандартный корень репозитория
# export LITE_ZIP="/workspace/RakSAMP Lite.zip"
