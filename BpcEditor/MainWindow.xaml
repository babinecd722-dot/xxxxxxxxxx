<Window x:Class="BpcEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BpcEditor.ViewModels"
        Title="BPC Editor" Height="720" Width="1100"
        MinHeight="520" MinWidth="820"
        WindowStyle="None"
        Background="#0D0D0D"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Loaded="Window_Loaded"
        Opacity="0">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- Горячие клавиши -->
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenBpcCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveBpcCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Заголовок -->
            <RowDefinition Height="50"/>   <!-- Панель инструментов -->
            <RowDefinition Height="*"/>    <!-- Основное содержимое -->
            <RowDefinition Height="34"/>   <!-- Строка состояния -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             ЗАГОЛОВОК ОКНА
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#111111">
            <Grid>
                <!-- Красная полоса-акцент сверху -->
                <Border Height="2" VerticalAlignment="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#DC143C" Offset="0"/>
                            <GradientStop Color="#8B0000" Offset="0.5"/>
                            <GradientStop Color="#DC143C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Заголовок -->
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <!-- Профессиональный логотип: стилизованный куб/архив -->
                    <Canvas Width="26" Height="26" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="LogoRotate" Angle="0" CenterX="13" CenterY="13"/>
                        </Canvas.RenderTransform>
                        <!-- Задняя грань -->
                        <Path Data="M13,2 L24,8 L24,20 L13,26 L2,20 L2,8 Z"
                              Fill="#1A0000" Stroke="#DC143C" StrokeThickness="1.2"/>
                        <!-- Левая грань -->
                        <Path Data="M2,8 L13,14 L13,26 L2,20 Z" Fill="#4A0A14" Opacity="0.8"/>
                        <!-- Правая грань -->
                        <Path Data="M24,8 L13,14 L13,26 L24,20 Z" Fill="#8B0000" Opacity="0.7"/>
                        <!-- Верхняя грань -->
                        <Path Data="M13,2 L24,8 L13,14 L2,8 Z" Fill="#DC143C" Opacity="0.9"/>
                        <!-- Горизонтальная линия (лента архива) -->
                        <Path Data="M5,13 L13,17 L21,13" Stroke="#FF4060" StrokeThickness="1" Opacity="0.8"/>
                        <!-- Блик -->
                        <Ellipse Canvas.Left="8" Canvas.Top="5" Width="5" Height="3"
                                 Fill="White" Opacity="0.12"/>
                    </Canvas>
                    <TextBlock Text="BPC" Foreground="#DC143C" FontSize="15" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" EDITOR" Foreground="#F0F0F0" FontSize="15" FontWeight="Light"
                               VerticalAlignment="Center"/>
                    <TextBlock Foreground="#555555" FontSize="12" Margin="14,2,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value=""/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsArchiveLoaded}" Value="True">
                                        <Setter Property="Text" Value="{Binding ArchiveName, StringFormat='— {0}'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Кнопки окна -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="─" Click="MinimizeButton_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource TitleBarButton}"/>
                    <Button x:Name="MaxBtn" Content="□" Click="MaximizeButton_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource TitleBarButton}"/>
                    <Button Click="CloseButton_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource TitleBarCloseButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ПАНЕЛЬ ИНСТРУМЕНТОВ
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0F0F0F" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                <Button Content="📂  Открыть" Command="{Binding OpenBpcCommand}" Margin="0,0,8,0"
                        ToolTip="Открыть BPC-архив (Ctrl+O)"/>
                <Button Content="💾  Сохранить" Command="{Binding SaveBpcCommand}" Margin="0,0,8,0"
                        ToolTip="Сохранить BPC-архив (Ctrl+S)"/>
                <Button Content="📤  Экспорт всех" Command="{Binding ExportAllCommand}" Margin="0,0,8,0"
                        ToolTip="Экспорт всех файлов архива"/>

                <Border Width="1" Background="#2A2A2A" Margin="8,6"/>

                <Button Content="🖼  BTX → PNG" Command="{Binding ExportPngCommand}" Margin="8,0,8,0"
                        ToolTip="Конвертировать выбранный BTX в PNG"/>
                <Button Content="📥  PNG → BTX" Command="{Binding ImportPngCommand}" Margin="0,0,0,0"
                        ToolTip="Заменить выбранный BTX из PNG"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ОСНОВНАЯ ОБЛАСТЬ
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Панель файлов (дерево) ──────────────────────── -->
            <Border Background="#0F0F0F">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок панели -->
                    <Border Background="#121212" Padding="14,9" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◈" Foreground="#DC143C" FontSize="12" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Ф А Й Л Ы  А Р Х И В А" Foreground="#707070" FontSize="10"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Дерево файлов -->
                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding FileTree}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              PreviewMouseRightButtonDown="TreeView_PreviewMouseRightButtonDown"
                              Padding="6"
                              Visibility="{Binding IsArchiveLoaded, Converter={StaticResource BoolToVis}}">
                        <!-- Переопределяем цвета выделения -->
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#40DC143C"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F0F0F0"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#25DC143C"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#F0F0F0"/>
                        </TreeView.Resources>

                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="📤  Экспорт файла" Command="{Binding ExportFileCommand}"/>
                                <MenuItem Header="🖼  Экспорт как PNG" Command="{Binding ExportPngCommand}"/>
                                <Separator/>
                                <MenuItem Header="📥  Импорт файла" Command="{Binding ImportFileCommand}"/>
                                <MenuItem Header="📥  Импорт PNG → BTX" Command="{Binding ImportPngCommand}"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,3">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,7,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8E8" FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SizeText}" Foreground="#4A4A4A" FontSize="10.5"
                                               Margin="10,2,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <!-- Пустое состояние -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding IsArchiveLoaded, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="📦" FontSize="56" HorizontalAlignment="Center" Opacity="0.2"/>
                        <TextBlock Text="Перетащите .bpc файл сюда" Foreground="#444444" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="или нажмите «Открыть»" Foreground="#333333" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Разделитель ──────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch"/>

            <!-- ── Панель просмотра ─────────────────────────────── -->
            <Border Grid.Column="2" Background="#0D0D0D">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Область превью -->
                    <Border Margin="10" CornerRadius="8" ClipToBounds="True">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#0E0E0E">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,16,16"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#141414">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,8,8"/>
                                                    <RectangleGeometry Rect="8,8,8,8"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>

                        <Grid>
                            <!-- Изображение -->
                            <Image x:Name="PreviewImageControl"
                                   Source="{Binding PreviewImage}"
                                   Stretch="Uniform" Margin="20"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Visibility="{Binding IsImageSelected, Converter={StaticResource BoolToVis}}">
                                <Image.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                                </Image.Effect>
                            </Image>

                            <!-- Плейсхолдер -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding IsImageSelected, Converter={StaticResource InverseBoolToVis}}">
                                <Border Width="80" Height="80" CornerRadius="40" Background="#15DC143C"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="👁" FontSize="36" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Opacity="0.5"/>
                                </Border>
                                <TextBlock Text="Выберите файл для просмотра" Foreground="#3A3A3A" FontSize="14"
                                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                <TextBlock Text="BTX-текстуры отображаются как изображения" Foreground="#2A2A2A"
                                           FontSize="11.5" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Информация о файле + действия -->
                    <Border Grid.Row="1" Background="#111111" Padding="16,12" Margin="10,0,10,10"
                            CornerRadius="8" BorderBrush="#1A1A1A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding FileInfoText}" Foreground="#909090" FontSize="12.5"
                                       TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="20"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                        Margin="16,0,0,0">
                                <Button Content="💾 Экспорт" Command="{Binding ExportFileCommand}"
                                        FontSize="11.5" Padding="12,6" Margin="0,0,6,0"/>
                                <Button Content="📥 Импорт" Command="{Binding ImportFileCommand}"
                                        FontSize="11.5" Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             СТРОКА СОСТОЯНИЯ
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статус -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#444444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsArchiveLoaded}" Value="True">
                                        <Setter Property="Fill" Value="#00CC66"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Fill" Value="#FFB800"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="{Binding StatusText}" Foreground="#707070" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Прогресс -->
                <ProgressBar Grid.Column="1" Value="{Binding Progress}" Maximum="100"
                             Margin="20,0" VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                <!-- Версия -->
                <TextBlock Grid.Column="2" Text="v1.0" Foreground="#333333" FontSize="10.5"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
